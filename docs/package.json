{
  "name": "ido4-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync-diagrams": "mkdir -p public/diagrams && cp ../diagrams/*.html public/diagrams/",
    "dev": "npm run sync-diagrams && astro dev",
    "generate-previews": "npm run sync-diagrams && node scripts/generate-previews.mjs",
    "build": "npm run generate-previews && astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/starlight": "0.33.0",
    "astro": "5.5.5",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "puppeteer": "^24.0.0"
  },
  "overrides": {
    "@astrojs/sitemap": "3.6.0"
  }
}
